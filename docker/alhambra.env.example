APP_NAME=Alhambra
APP_ENV=production
# APP_KEY is auto-generated on first start if empty
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8080

FRONTEND_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=alhambra
DB_USERNAME=alhambra
DB_PASSWORD=alhambra

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=database

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MAIL_MAILER=log
