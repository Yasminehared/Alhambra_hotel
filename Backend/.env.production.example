##############################################################
# Alhambra Hotel — Production Environment Configuration
# Copy this file to .env and fill in real credentials.
# NEVER commit the actual .env file to version control.
##############################################################

# ─── Application ──────────────────────────────────────────
APP_NAME="Alhambra Hotel"
APP_ENV=production
APP_KEY=                         # Run: php artisan key:generate
APP_DEBUG=false                  # MUST be false in production
APP_URL=https://yourdomain.com
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# ─── Logging ───────────────────────────────────────────────
# Use 'daily' in production to rotate logs automatically
LOG_CHANNEL=daily
LOG_STACK=daily,slack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                # Use 'warning' or 'error' in production
LOG_DAILY_DAYS=30

# Slack notifications for critical errors
LOG_SLACK_WEBHOOK_URL=           # Your Slack webhook URL
LOG_SLACK_USERNAME="Alhambra Hotel Alert"
LOG_SLACK_EMOJI=":hotel:"

# ─── Database ─────────────────────────────────────────────
# Switch to MySQL/PostgreSQL for production
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=alhambra_production
DB_USERNAME=alhambra_user
DB_PASSWORD=                     # Use a strong password

# ─── Session & Security ────────────────────────────────────
SESSION_DRIVER=database          # Use 'redis' if Redis available
SESSION_LIFETIME=120             # Minutes
SESSION_ENCRYPT=true             # Enable session encryption
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com   # Include subdomain support
SESSION_SECURE_COOKIE=true       # HTTPS only cookies
SESSION_HTTP_ONLY=true

# ─── Broadcasting ─────────────────────────────────────────
BROADCAST_CONNECTION=log         # Use 'pusher' or 'reverb' for real-time

# ─── File Storage ─────────────────────────────────────────
FILESYSTEM_DISK=local            # Change to 's3' for cloud storage
# For S3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=alhambra-production
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Queue ────────────────────────────────────────────────
QUEUE_CONNECTION=database        # Use 'redis' for production scale
# For Redis:
# QUEUE_CONNECTION=redis

# ─── Cache ────────────────────────────────────────────────
CACHE_STORE=database             # Use 'redis' for production scale
# CACHE_PREFIX=alhambra_

# ─── Redis ────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=                  # Set a strong Redis password
REDIS_PORT=6379

# ─── Email ────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.mailgun.org       # Or sendgrid, ses, postmark, etc.
MAIL_PORT=587
MAIL_USERNAME=                   # Your SMTP username
MAIL_PASSWORD=                   # Your SMTP password
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="Alhambra Hotel"

# ─── Security ─────────────────────────────────────────────
BCRYPT_ROUNDS=12                 # Keep at 12 for production

# ─── Laravel Sanctum ──────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=yourdomain.com,api.yourdomain.com

# ─── Rate Limiting ────────────────────────────────────────
# Login is already throttled at 5 attempts/minute via routes/api.php
# Booking is throttled at 10 attempts/minute

# ─── Filament Admin Panel ─────────────────────────────────
FILAMENT_FILESYSTEM_DISK=public

# ─── Telescope (Dev Only — disable in production) ─────────
TELESCOPE_ENABLED=false

# ─── Pulse Monitoring ─────────────────────────────────────
PULSE_ENABLED=true               # Laravel Pulse for system health

# ─── Nightwatch (Laravel Cloud monitoring) ────────────────
NIGHTWATCH_ENABLED=false

# ─── Vite / Frontend ──────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_API_URL="${APP_URL}/api"
